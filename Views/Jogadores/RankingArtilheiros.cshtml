@model List<Futebol.Models.RankingArtilheiroViewModel>

<h2 class="text-center mb-4">Ranking de Artilheiros</h2>

<div class="p-4 mb-5" style="background-color: #001f3f; border-radius: 10px;">
    <!-- Azul escuro -->
    <div class="d-flex flex-column gap-4">
        @foreach (var item in Model)
        {
            <div class="card w-100 text-dark" style="background-color: #add8e6; border: 2px solid #87ceeb;">
                <!-- Azul claro com borda -->
                <div class="card-body">
                    <h5 class="card-title text-center">@item.JogadorNome</h5>
                    <p class="card-text text-center">
                        <strong>Time:</strong> @item.TimeNome <br />
                        <strong>Gols Marcados:</strong> @item.TotalGols
                    </p>
                </div>
            </div>
        }
    </div>
</div>
