<!DOCTYPE html>
<html>
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - Liga Tabajara</title>
    <link href="https://cdn.jsdelivr.net/npm/bootswatch@5.3.2/dist/flatly/bootstrap.min.css" rel="stylesheet">
    @Styles.Render("~/Content/css")
    @Scripts.Render("~/bundles/modernizr")
    <style>
        .nav-link-custom {
            font-weight: bold;
            padding: 8px 15px;
            border-radius: 10px;
            margin-right: 8px;
            transition: background-color 0.3s, color 0.3s;
        }

        .liga-btn {
            background-color: #28a745;
            color: white;
        }

        .classificacao-btn {
            background-color: #ffc107;
            color: black;
        }

        .artilheiros-btn {
            background-color: #007bff;
            color: white;
        }

        .default-btn {
            background-color: #6c757d;
            color: white;
        }

        .nav-link-custom:hover {
            opacity: 0.8;
        }

        footer {
            text-align: center;
            padding: 20px;
            margin-top: 40px;
            background-color: #343a40;
            color: #ccc;
            border-radius: 10px;
        }

        .body-content {
            margin-top: 20px;
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark bg-dark shadow-sm mb-4">
        <div class="container">
            @Html.ActionLink("Liga Tabajara", "Index", "Home", new { area = "" }, new { @class = "navbar-brand fw-bold" })
            <button type="button" class="navbar-toggler" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" title="Alternar a navegação" aria-controls="navbarSupportedContent"
                    aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse d-sm-inline-flex justify-content-end">
                <ul class="navbar-nav">
                    <li>@Html.ActionLink("Liga", "Index", "Home", new { area = "" }, new { @class = "nav-link nav-link-custom liga-btn" })</li>
                    <li>@Html.ActionLink("Classificação", "Classificacao", "Home", new { area = "" }, new { @class = "nav-link nav-link-custom classificacao-btn" })</li>
                    <li>@Html.ActionLink("Artilheiros", "RankingArtilheiros", "Jogadores", new { area = "" }, new { @class = "nav-link nav-link-custom artilheiros-btn" })</li>
                    <li>@Html.ActionLink("Partidas", "Index", "Partidas", new { area = "" }, new { @class = "nav-link nav-link-custom default-btn" })</li>
                    <li>@Html.ActionLink("Times", "Index", "Times", new { area = "" }, new { @class = "nav-link nav-link-custom default-btn" })</li>
                    <li>@Html.ActionLink("Jogadores", "Index", "Jogadores", new { area = "" }, new { @class = "nav-link nav-link-custom default-btn" })</li>
                    <li>@Html.ActionLink("Funcionários", "Index", "ComissaoTecnica", new { area = "" }, new { @class = "nav-link nav-link-custom default-btn" })</li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container body-content">
        @RenderBody()
        <hr />
        <footer>
            <p>&copy; @DateTime.Now.Year - Liga Tabajara de Futebol</p>
        </footer>
    </div>

    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")
    @RenderSection("scripts", required: false)
</body>
</html>
